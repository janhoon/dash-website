---
import '../styles/global.css';
import HeaderNav from '../components/landing/HeaderNav.astro';
import HeroSection from '../components/landing/HeroSection.astro';
import FeaturesSection from '../components/landing/FeaturesSection.astro';
import DatasourcesSection from '../components/landing/DatasourcesSection.astro';
import TestimonialsSection from '../components/landing/TestimonialsSection.astro';
import ComparisonSection from '../components/landing/ComparisonSection.astro';
import CtaSection from '../components/landing/CtaSection.astro';
import FooterSection from '../components/landing/FooterSection.astro';
import { structuredDataPayloads } from '../data/landing';

const pageTitle = 'Ace Observability | Open-Source Monitoring Dashboard';
const pageDescription =
  'Ace Observability is a truly open-source monitoring dashboard with 11 datasource integrations — Prometheus, Loki, Tempo, VictoriaMetrics, ClickHouse, CloudWatch, and more. No paid tiers.';
const pageUrl = '/';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="192x192" href="/ace-favicon-clean.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="theme-color" content="#0B0D0F" />
    <link rel="canonical" href={pageUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Ace Observability" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content="/screenshot-service-health.png" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content="/screenshot-service-health.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;1,400&display=swap"
    />
    <link rel="preload" as="image" href="/screenshot-service-health.png" type="image/png" />

    {
      structuredDataPayloads.map((payload) => (
        <script type="application/ld+json" set:html={JSON.stringify(payload)}></script>
      ))
    }
  </head>

  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-30 focus:rounded-md focus:bg-emerald-600 focus:px-3 focus:py-2 focus:text-sm focus:font-semibold focus:text-white"
    >
      Skip to main content
    </a>

    <HeaderNav />

    <main id="main-content">
      <HeroSection />
      <FeaturesSection />
      <DatasourcesSection />
      <TestimonialsSection />
      <ComparisonSection />
      <CtaSection />
    </main>

    <FooterSection />

  </body>
</html>
