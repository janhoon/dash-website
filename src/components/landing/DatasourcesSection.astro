---
type Datasource = {
  name: string;
  category: string;
  color: string;
  desc: string;
};

const datasources: Datasource[] = [
  { name: 'Prometheus', category: 'Metrics', color: 'primary', desc: 'PromQL metrics from any Prometheus-compatible endpoint.' },
  { name: 'VictoriaMetrics', category: 'Metrics', color: 'primary', desc: 'High-performance Prometheus-compatible metrics storage.' },
  { name: 'Loki', category: 'Logs', color: 'info', desc: 'LogQL log exploration with label-based filtering.' },
  { name: 'VictoriaLogs', category: 'Logs', color: 'info', desc: 'Cost-efficient log storage with LogQL support.' },
  { name: 'Elasticsearch', category: 'Logs', color: 'info', desc: 'Full-text log and event search with index patterns.' },
  { name: 'ClickHouse', category: 'Analytics', color: 'viz3', desc: 'SQL analytics and log queries on ClickHouse databases.' },
  { name: 'CloudWatch', category: 'Cloud', color: 'viz9', desc: 'AWS CloudWatch metrics and logs via IAM credentials.' },
  { name: 'Tempo', category: 'Traces', color: 'secondary', desc: 'Distributed trace search and span timeline views.' },
  { name: 'VictoriaTraces', category: 'Traces', color: 'secondary', desc: 'OpenTelemetry-compatible trace storage and search.' },
  { name: 'VMAlert', category: 'Alerting', color: 'error', desc: 'View firing VMAlert rules and alert history.' },
  { name: 'AlertManager', category: 'Alerting', color: 'error', desc: 'Manage silences, receivers, and alert routing.' },
];

const badgeColors: Record<string, string> = {
  primary: 'bg-[var(--color-primary)]/15 text-[var(--color-primary)]',
  info: 'bg-[var(--color-info)]/15 text-[var(--color-info)]',
  viz3: 'bg-[var(--color-viz-3)]/15 text-[var(--color-viz-3)]',
  viz9: 'bg-[var(--color-viz-9)]/15 text-[var(--color-viz-9)]',
  secondary: 'bg-[var(--color-secondary)]/15 text-[var(--color-secondary)]',
  error: 'bg-[var(--color-error)]/15 text-[var(--color-error)]',
};
---

<section id="datasources" class="section-band dark-section" aria-labelledby="datasources-title">
  <div class="section-inner">
    <p class="m-0 font-[family-name:var(--font-mono)] text-xs uppercase tracking-[0.06em] text-[var(--color-primary)]">Integrations</p>
    <h2 id="datasources-title" class="mt-2 text-2xl font-bold tracking-[-0.03em] md:text-3xl">11 datasource integrations out of the box</h2>
    <p class="mt-4 max-w-3xl text-[var(--color-text-secondary)]">
      Connect Ace to your existing observability infrastructure without plugins or marketplace purchases.
    </p>

    <div class="mt-6 grid grid-cols-2 gap-3 md:grid-cols-3 xl:grid-cols-4">
      {
        datasources.map((ds) => (
          <article class="rounded-[var(--radius-lg)] border border-[var(--color-stroke-subtle)] bg-[var(--color-surface-card)] p-4 shadow-[var(--shadow-sm)] transition-shadow duration-[var(--motion-fast)] hover:shadow-[var(--shadow-md)]">
            <span class={`inline-block rounded-md px-2 py-0.5 text-xs font-semibold mb-3 ${badgeColors[ds.color]}`}>
              {ds.category}
            </span>
            <h3 class="m-0 text-sm font-semibold text-[var(--color-text-primary)] mb-1">{ds.name}</h3>
            <p class="m-0 text-xs text-[var(--color-text-muted)]">{ds.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
