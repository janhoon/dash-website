---
const features = [
  {
    title: 'Multi-datasource monitoring',
    desc: 'Query Prometheus, Loki, Tempo, VictoriaMetrics, ClickHouse, Elasticsearch, and CloudWatch from one interface.',
    icon: [
      'M4 6.5a8 3 0 1 0 16 0a8 3 0 1 0 -16 0',
      'M4 6.5v5a8 3 0 0 0 16 0v-5',
      'M4 11.5v5a8 3 0 0 0 16 0v-5',
    ],
  },
  {
    title: 'Self-hosted deployment',
    desc: 'Run Ace in your own environment. Full control over your data, network, and infrastructure.',
    icon: ['M12 3l9 4.5v4.7c0 5.3-3.5 8.6-9 9.8c-5.5-1.2-9-4.5-9-9.8V7.5L12 3z', 'M9 12l2 2l4-4'],
  },
  {
    title: 'Grafana dashboard import',
    desc: 'Import existing Grafana JSON dashboards and start monitoring without rebuilding from scratch.',
    icon: ['M4 6h9v12H4z', 'M11 9h9v12h-9z', 'M7 10h3M7 13h3M14 13h3M14 16h3'],
  },
  {
    title: 'Alerting workflows',
    desc: 'Create alert rules from datasource queries and investigate incidents in one place.',
    icon: [
      'M12 4a5 5 0 0 1 5 5v3.5l1.6 2.7c.2.3 0 .8-.4.8H5.8c-.4 0-.6-.5-.4-.8L7 12.5V9a5 5 0 0 1 5-5z',
      'M10 18a2 2 0 0 0 4 0',
    ],
  },
  {
    title: 'SSO and access control',
    desc: 'Configure Google or Microsoft SSO, manage members, and apply role-based permissions.',
    icon: ['M7 11a4 4 0 1 1 0-8a4 4 0 0 1 0 8zM17 21a4 4 0 1 0 0-8a4 4 0 0 0 0 8z', 'M10.5 8.5l3 3M13.5 15.5l3-3'],
  },
  {
    title: 'AI-powered dashboards',
    desc: 'Describe what you want in natural language and get a complete dashboard generated by AI.',
    icon: ['M12 2a4 4 0 0 0-4 4v2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8a2 2 0 0 0-2-2h-2V6a4 4 0 0 0-4-4z', 'M9 14l2 2l4-4'],
  },
];
---

<div class="mt-12 grid grid-cols-2 gap-4 md:grid-cols-3">
  {features.map((f) => (
    <div class="rounded-[var(--radius-lg)] border border-[var(--color-stroke-subtle)] bg-[var(--color-surface-card)] p-5 transition-shadow duration-[var(--motion-fast)] hover:shadow-[var(--shadow-md)]">
      <svg viewBox="0 0 24 24" class="h-6 w-6 stroke-[var(--color-primary)] mb-3" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        {f.icon.map((path) => <path d={path}></path>)}
      </svg>
      <h3 class="m-0 text-sm font-semibold text-[var(--color-text-primary)]">{f.title}</h3>
      <p class="m-0 mt-1.5 text-xs leading-relaxed text-[var(--color-text-muted)]">{f.desc}</p>
    </div>
  ))}
</div>
