<section id="cta" class="section-band dark-section" aria-labelledby="cta-title">
  <div class="section-inner">
    <h2 id="cta-title" class="m-0 text-2xl font-bold tracking-[-0.03em] md:text-3xl">Run Ace in your own environment</h2>
    <p class="mt-4 max-w-3xl text-[var(--color-text-secondary)]">
      Start with a truly open-source dashboard for metrics, logs, and traces — no paid tiers or
      license-gated features.
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <a class="btn-primary" href="https://github.com/aceobservability/ace" target="_blank" rel="noreferrer">Get Started Free</a>
      <a class="btn-secondary" href="https://github.com/aceobservability/ace" target="_blank" rel="noreferrer">View on GitHub</a>
    </div>

    <div class="mt-5 flex flex-wrap gap-2" aria-label="GitHub stats badges">
      <a class="inline-flex" href="https://github.com/aceobservability/ace/stargazers" target="_blank" rel="noreferrer" aria-label="Ace GitHub stars">
        <img
          src="https://img.shields.io/github/stars/aceobservability/ace?style=flat-square&label=GitHub%20Stars"
          alt="GitHub stars badge"
          loading="lazy"
          decoding="async"
        />
      </a>
      <a class="inline-flex" href="https://github.com/aceobservability/ace/network/members" target="_blank" rel="noreferrer" aria-label="Ace GitHub forks">
        <img
          src="https://img.shields.io/github/forks/aceobservability/ace?style=flat-square&label=GitHub%20Forks"
          alt="GitHub forks badge"
          loading="lazy"
          decoding="async"
        />
      </a>
      <a class="inline-flex" href="https://github.com/aceobservability/ace/commits/main" target="_blank" rel="noreferrer" aria-label="Ace latest commit activity">
        <img
          src="https://img.shields.io/github/last-commit/aceobservability/ace?style=flat-square&label=Last%20Commit"
          alt="GitHub last commit badge"
          loading="lazy"
          decoding="async"
        />
      </a>
    </div>
  </div>
</section>
