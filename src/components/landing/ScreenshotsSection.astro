---
import { screenshotGallery } from '../../data/landing';
---

<section id="screenshots" class="section-band bg-[#0a1628]" aria-labelledby="screenshots-title">
  <div class="section-inner">
    <h2 id="screenshots-title" class="m-0 text-2xl font-semibold text-slate-50 md:text-3xl">Product screenshots</h2>
    <p class="mt-4 max-w-3xl text-slate-300">
      See Ace in action across dashboards, datasource setup, query editing, alerts, and organization settings.
    </p>

    <ul class="mt-6 grid list-none gap-3 p-0 md:grid-cols-2 xl:grid-cols-3" aria-label="Ace screenshot gallery">
      {
        screenshotGallery.map((screenshot) => (
          <li class="m-0" id={screenshot.id}>
            <article class="h-full rounded-xl border border-slate-700/50 bg-[#0f1d32] p-3">
              <figure class="m-0 grid gap-3">
                <picture class="overflow-hidden rounded-lg border border-slate-700/50">
                  <source srcset={screenshot.webp} type="image/webp" />
                  <img
                    class="block h-auto w-full"
                    src={screenshot.jpg}
                    alt={screenshot.alt}
                    width="1280"
                    height="720"
                    loading="lazy"
                    decoding="async"
                  />
                </picture>
                <figcaption class="grid gap-1">
                  <span class="text-sm font-semibold text-slate-50">{screenshot.title}</span>
                  <span class="text-sm text-slate-300">{screenshot.description}</span>
                </figcaption>
              </figure>
            </article>
          </li>
        ))
      }
    </ul>
  </div>
</section>
