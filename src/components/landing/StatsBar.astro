---
const stats = [
  {
    value: '11',
    label: 'Datasources',
    sparkline: 'M0,8 L3,6 L6,7 L9,4 L12,5 L15,3 L18,4 L21,2 L24,3',
  },
  {
    value: '100%',
    label: 'Open Source',
    sparkline: 'M0,4 L4,4 L8,4 L12,4 L16,4 L20,4 L24,4',
  },
  {
    value: null,
    label: 'GitHub Stars',
    sparkline: 'M0,10 L4,9 L8,7 L12,6 L16,4 L20,3 L24,2',
    dynamic: true,
  },
  {
    value: 'Zero',
    label: 'Paid Tiers',
    sparkline: 'M0,4 L4,4 L8,4 L12,4 L16,4 L20,4 L24,4',
  },
];
---

<div class="mt-10 grid grid-cols-2 gap-6 md:grid-cols-4 md:gap-0 md:divide-x md:divide-[var(--color-stroke-subtle)]" aria-label="Key product stats">
  {
    stats.map((stat) => (
      <div class="flex flex-col items-center text-center md:px-6">
        <div class="flex items-end gap-2">
          {stat.dynamic ? (
            <span id="gh-stars" class="font-[family-name:var(--font-mono)] text-4xl font-bold text-[var(--color-text-primary)] md:text-5xl">&mdash;</span>
          ) : (
            <span class="font-[family-name:var(--font-mono)] text-4xl font-bold text-[var(--color-text-primary)] md:text-5xl">{stat.value}</span>
          )}
          <svg class="mb-2 h-3 w-6 text-[var(--color-primary)]/40" viewBox="0 0 24 12" fill="none" aria-hidden="true">
            <path d={stat.sparkline} stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </div>
        <span class="mt-1 font-[family-name:var(--font-mono)] text-xs uppercase tracking-[0.06em] text-[var(--color-text-muted)]">{stat.label}</span>
      </div>
    ))
  }
</div>

<script is:inline>
  (function() {
    var el = document.getElementById('gh-stars');
    if (!el) return;
    fetch('https://api.github.com/repos/aceobservability/ace')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (typeof data.stargazers_count === 'number') {
          var count = data.stargazers_count;
          el.textContent = count >= 1000 ? (count / 1000).toFixed(1).replace(/\.0$/, '') + 'K' : String(count);
        }
      })
      .catch(function() {
        el.textContent = '—';
      });
  })();
</script>
