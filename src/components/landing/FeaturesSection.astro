---
import { screenshotGallery } from '../../data/landing';
---

<section id="features" class="section-band alt-section" aria-labelledby="features-title">
  <div class="section-inner">
    <p class="m-0 font-[family-name:var(--font-mono)] text-xs uppercase tracking-[0.06em] text-[var(--color-primary)]">Dashboards</p>
    <h2 id="features-title" class="mt-2 text-2xl font-bold tracking-[-0.03em] md:text-3xl">See Ace In Action</h2>
    <p class="mt-4 max-w-3xl text-[var(--color-text-secondary)]">
      Real dashboards running on live telemetry data — metrics, logs, traces, and infrastructure.
    </p>
  </div>

  <!-- Carousel -->
  <div class="mt-8 relative" id="feature-carousel">
    <div class="flex items-center justify-center gap-4 px-4 md:px-8">
      <!-- Prev peek -->
      <button
        id="carousel-prev"
        type="button"
        class="hidden md:block flex-shrink-0 w-[12%] cursor-pointer rounded-[var(--radius-lg)] border-0 bg-transparent p-0 opacity-30 transition-opacity duration-300 hover:opacity-60"
        aria-label="Previous dashboard"
      >
        <img id="peek-prev" class="block h-auto w-full rounded-[var(--radius-lg)]" src="" alt="" loading="lazy" decoding="async" />
      </button>

      <!-- Active slide -->
      <div class="flex-1 min-w-0 max-w-5xl">
        <div class="overflow-hidden rounded-[var(--radius-lg)] border border-[var(--color-stroke-subtle)] bg-[var(--color-surface)] shadow-[var(--shadow-lg)]">
          <div class="relative">
            <button
              id="carousel-active-btn"
              type="button"
              class="block w-full cursor-zoom-in border-0 bg-transparent p-0"
              aria-label="Enlarge screenshot"
            >
              <img
                id="active-img"
                class="block h-auto w-full"
                src=""
                alt=""
                width="1440"
                height="900"
                decoding="async"
              />
            </button>

            <!-- Overlay arrows -->
            <button
              id="carousel-arrow-prev"
              type="button"
              class="absolute left-3 top-1/2 -translate-y-1/2 flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-surface)]/70 text-[var(--color-text-primary)] backdrop-blur-sm transition hover:bg-[var(--color-surface)]/90"
              aria-label="Previous dashboard"
            >
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            </button>
            <button
              id="carousel-arrow-next"
              type="button"
              class="absolute right-3 top-1/2 -translate-y-1/2 flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-surface)]/70 text-[var(--color-text-primary)] backdrop-blur-sm transition hover:bg-[var(--color-surface)]/90"
              aria-label="Next dashboard"
            >
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
            </button>
          </div>

          <!-- Caption bar — just title -->
          <div class="border-t border-[var(--color-stroke-subtle)] px-6 py-3">
            {screenshotGallery.map((s, i) => (
              <div class:list={["carousel-caption", i === 0 ? "" : "hidden"]} data-caption={i}>
                <p class="m-0 text-sm font-semibold text-[var(--color-text-primary)]">{s.title}</p>
                <p class="m-0 text-xs text-[var(--color-text-muted)]">{s.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Next peek -->
      <button
        id="carousel-next"
        type="button"
        class="hidden md:block flex-shrink-0 w-[12%] cursor-pointer rounded-[var(--radius-lg)] border-0 bg-transparent p-0 opacity-30 transition-opacity duration-300 hover:opacity-60"
        aria-label="Next dashboard"
      >
        <img id="peek-next" class="block h-auto w-full rounded-[var(--radius-lg)]" src="" alt="" loading="lazy" decoding="async" />
      </button>
    </div>

    <!-- Dot indicators -->
    <div class="mt-4 flex items-center justify-center gap-2" id="carousel-dots" aria-label="Dashboard slides">
      {screenshotGallery.map((s, i) => (
        <button
          type="button"
          class:list={[
            "h-2 rounded-full transition-all duration-300",
            i === 0 ? "w-6 bg-[var(--color-primary)]" : "w-2 bg-[var(--color-stroke-strong)] hover:bg-[var(--color-text-muted)]",
          ]}
          data-dot={i}
          aria-label={`Go to ${s.title}`}
        />
      ))}
    </div>
  </div>
</section>

<!-- Lightbox modal -->
<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="Enlarged screenshot"
>
  <button
    id="lightbox-close"
    type="button"
    class="absolute right-4 top-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white transition hover:bg-white/20"
    aria-label="Close lightbox"
  >
    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12" /></svg>
  </button>
  <img
    id="lightbox-img"
    class="max-h-[90vh] max-w-[90vw] rounded-lg object-contain shadow-2xl"
    src=""
    alt=""
  />
</div>

<script define:vars={{ slides: screenshotGallery.map(s => ({ src: s.src, alt: s.alt, title: s.title })) }}>
  const total = slides.length;
  let current = 0;
  let autoTimer;

  const activeImg = document.getElementById('active-img');
  const activeBtn = document.getElementById('carousel-active-btn');
  const peekPrev = document.getElementById('peek-prev');
  const peekNext = document.getElementById('peek-next');
  const captions = document.querySelectorAll('[data-caption]');
  const dots = document.querySelectorAll('[data-dot]');

  function wrap(i) { return ((i % total) + total) % total; }

  function goTo(index) {
    current = wrap(index);
    const prev = wrap(current - 1);
    const next = wrap(current + 1);

    activeImg.src = slides[current].src;
    activeImg.alt = slides[current].alt;
    activeBtn.setAttribute('aria-label', 'Enlarge screenshot: ' + slides[current].title);

    peekPrev.src = slides[prev].src;
    peekPrev.alt = slides[prev].title;
    peekNext.src = slides[next].src;
    peekNext.alt = slides[next].title;

    captions.forEach(function(c, i) { c.classList.toggle('hidden', i !== current); });
    dots.forEach(function(d, i) {
      if (i === current) {
        d.className = 'h-2 w-6 rounded-full bg-[var(--color-primary)] transition-all duration-300';
      } else {
        d.className = 'h-2 w-2 rounded-full bg-[var(--color-stroke-strong)] hover:bg-[var(--color-text-muted)] transition-all duration-300';
      }
    });
  }

  function resetAuto() {
    clearInterval(autoTimer);
    autoTimer = setInterval(function() { goTo(current + 1); }, 6000);
  }

  goTo(0);

  document.getElementById('carousel-prev').addEventListener('click', function() { goTo(current - 1); resetAuto(); });
  document.getElementById('carousel-next').addEventListener('click', function() { goTo(current + 1); resetAuto(); });
  document.getElementById('carousel-arrow-prev').addEventListener('click', function() { goTo(current - 1); resetAuto(); });
  document.getElementById('carousel-arrow-next').addEventListener('click', function() { goTo(current + 1); resetAuto(); });
  dots.forEach(function(dot, i) { dot.addEventListener('click', function() { goTo(i); resetAuto(); }); });
  resetAuto();

  var lightbox = document.getElementById('lightbox');
  var lightboxImg = document.getElementById('lightbox-img');

  function openLightbox() {
    lightboxImg.src = slides[current].src;
    lightboxImg.alt = slides[current].alt;
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }

  activeBtn.addEventListener('click', openLightbox);
  document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', function(e) { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeLightbox(); });
</script>
